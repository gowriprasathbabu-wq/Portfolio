{
  "name": "gowri-prasath-portfolio",
  "version": "1.0.0",
  "description": "Enterprise Portfolio - Gowri Prasath Babu | Senior Full Stack Software Engineer",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "serve:ssr": "node dist/portfolio/server/server.mjs",
    "build:ssr": "ng build --configuration production && ng run portfolio:server",
    "prerender": "ng build --configuration production",
    "test": "ng test",
    "lint": "eslint src --ext .ts,.html",
    "format": "prettier --write src/**/*.{ts,html,scss}",
    "docker:build": "docker build -t gowri-portfolio .",
    "docker:run": "docker run -p 4000:4000 gowri-portfolio"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/material": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular/platform-server": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@angular/ssr": "^20.0.0",
    "@angular/cdk": "^20.0.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.7.0",
    "zone.js": "~0.15.0",
    "emailjs-com": "^3.2.0",
    "express": "^4.18.2",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@types/express": "^4.17.21",
    "@types/compression": "^1.7.5",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-angular": "^4.1.0",
    "jasmine-core": "~5.3.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.3.0",
    "typescript": "~5.8.0"
  }
}
